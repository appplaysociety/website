<footer>
  <p>© 2025 PlaySociety. All rights reserved. &nbsp;|&nbsp; <a href="index.html">Home</a> &nbsp;|&nbsp; <a href="privacy.html">Privacy Policy</a></p>
</footer>

</body>
</html>
